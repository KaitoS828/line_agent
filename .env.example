# LINE Bot 設定
# LINE Developers Console > Messaging API タブ > Channel access token
LINE_CHANNEL_ACCESS_TOKEN=

# LINE Developers Console > Basic settings タブ > Channel secret
LINE_CHANNEL_SECRET=

# 自分のLINE User ID（python get_line_user_id.py で取得）
LINE_AUTHORIZED_USER_ID=

# Anthropic API キー（https://console.anthropic.com/）
ANTHROPIC_API_KEY=

# OpenAI API キー — 音声文字起こし Whisper 用（https://platform.openai.com/api-keys）
OPENAI_API_KEY=

# Google 認証トークン — token.json の中身をJSON文字列で（Gmail / Drive / Calendar / Sheets）
GOOGLE_TOKEN_JSON=

# Tavily API キー — Web検索用（https://tavily.com/）
TAVILY_API_KEY=

# Supabase — 会話記憶・監視データ（https://supabase.com/）
SUPABASE_URL=
SUPABASE_KEY=

# 天気表示の都市名（任意 — デフォルト: Tokyo）
# WEATHER_CITY=Tokyo

# スケジューラー通知時刻（任意 — デフォルト値あり）
# MORNING_NOTIFY_HOUR=7
# MORNING_NOTIFY_MINUTE=0
# EVENING_NOTIFY_HOUR=21
# EVENING_NOTIFY_MINUTE=0
