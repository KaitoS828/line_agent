# LINE Bot 設定
# LINE Developers Console > Messaging API タブ > Channel access token
LINE_CHANNEL_ACCESS_TOKEN=

# LINE Developers Console > Basic settings タブ > Channel secret
LINE_CHANNEL_SECRET=

# 自分のLINE User ID（python get_line_user_id.py で取得）
LINE_AUTHORIZED_USER_ID=

# Anthropic API キー（https://console.anthropic.com/）
ANTHROPIC_API_KEY=
